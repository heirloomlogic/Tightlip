{"kind":"article","seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvironmentSelection","doc:\/\/TightlipCore\/documentation\/TightlipCore\/ConfigGrammar"]},{"title":"How-To Guides","anchor":"How-To-Guides","generated":true,"identifiers":["doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvFileDirective"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"Multi-Environment Configs","modules":[{"name":"Tightlip"}],"roleHeading":"Article","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/SectionedConfigs"},"variants":[{"paths":["\/documentation\/tightlipcore\/sectionedconfigs"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Declare staging and production secrets in one file and select between them per build."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"When-to-Use-Sectioned-Configs","text":"When to Use Sectioned Configs","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reach for sectioned configs when the same property names need different values across environments — staging keys for development builds, production keys for release builds, perhaps a "},{"type":"codeVoice","code":"qa"},{"type":"text","text":" set for a release-candidate lane."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A flat config has no environment concept. If you have one set of values, stay flat."}]},{"type":"heading","anchor":"Format","text":"Format","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each top-level identifier followed by "},{"type":"codeVoice","code":":"},{"type":"text","text":" (with no value) is an environment section. Lines within a section are indented exactly 2 spaces:"}]},{"type":"codeListing","code":["# Secrets.yml","staging:","  revenueCatAPIKey: STAGING_REVENUECAT_API_KEY","  hmacSigningKey:   STAGING_HMAC_KEY","","production:","  revenueCatAPIKey: PROD_REVENUECAT_API_KEY","  hmacSigningKey:   PROD_HMAC_KEY"],"syntax":"yaml"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"All sections must declare the same set of property names.","type":"text"}]},{"type":"text","text":" Mismatched property sets fail at parse time — this prevents a release build from accidentally referencing a property that only exists in staging."}]},{"type":"paragraph","inlineContent":[{"text":"The active section is chosen at build time. For the rules — ","type":"text"},{"type":"codeVoice","code":"TIGHTLIP_ENV"},{"text":", Xcode ","type":"text"},{"type":"codeVoice","code":"CONFIGURATION"},{"text":", the auto-inference behavior — see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvironmentSelection"},{"text":".","type":"text"}]},{"type":"heading","anchor":"Naming-Convention-for-Env-Vars","text":"Naming Convention for Env Vars","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Devs working on several apps on the same machine see bare names like "},{"type":"codeVoice","code":"REVENUECAT_API_KEY"},{"type":"text","text":" collide. Prefix every env var with an app-specific tag — "},{"type":"codeVoice","code":"<APP_PREFIX>_<SECRET>"},{"type":"text","text":" in screaming snake case (e.g. "},{"type":"codeVoice","code":"ACME_REVENUECAT_API_KEY"},{"type":"text","text":"). Tightlip doesn’t enforce this; the convention just keeps configs across projects from stepping on each other."}]},{"type":"paragraph","inlineContent":[{"text":"The Swift-side property name (","type":"text"},{"code":"revenueCatAPIKey","type":"codeVoice"},{"text":") stays clean either way — only the env-var side gets the prefix.","type":"text"}]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/TightlipCore\/documentation\/TightlipCore"]]},"references":{"doc://TightlipCore/documentation/TightlipCore/EnvFileDirective":{"type":"topic","kind":"article","url":"\/documentation\/tightlipcore\/envfiledirective","role":"article","abstract":[{"type":"text","text":"Point Tightlip at a different shell-init file with the "},{"type":"codeVoice","code":"envFile:"},{"type":"text","text":" directive."}],"identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvFileDirective","title":"Overriding the Sourced Env File"},"doc://TightlipCore/documentation/TightlipCore/EnvironmentSelection":{"url":"\/documentation\/tightlipcore\/environmentselection","title":"Environment Selection","abstract":[{"type":"text","text":"How Tightlip picks the active section for a sectioned config."}],"type":"topic","identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvironmentSelection","kind":"article","role":"article"},"doc://TightlipCore/documentation/TightlipCore":{"identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore","type":"topic","abstract":[{"type":"text","text":"A SwiftPM build-tool plugin that generates a typed Swift "},{"type":"codeVoice","code":"Secrets"},{"type":"text","text":" enum from environment variables at build time."}],"title":"Tightlip","kind":"symbol","url":"\/documentation\/tightlipcore","role":"collection"},"doc://TightlipCore/documentation/TightlipCore/ConfigGrammar":{"title":"Config Grammar","kind":"article","url":"\/documentation\/tightlipcore\/configgrammar","identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/ConfigGrammar","abstract":[{"type":"text","text":"The accepted shape of "},{"type":"codeVoice","code":"Secrets.yml"},{"type":"text","text":", line by line."}],"role":"article","type":"topic"}}}