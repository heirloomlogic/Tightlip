{"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/TightlipCore\/documentation\/TightlipCore\/GettingStarted","doc:\/\/TightlipCore\/documentation\/TightlipCore\/SectionedConfigs"],"title":"Related Documentation"},{"generated":true,"anchor":"Reference","identifiers":["doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvironmentSelection"],"title":"Reference"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Tightlip parses a small, strict subset of YAML. The parser rejects anything ambiguous so config errors fail loudly at build time instead of silently emitting the wrong value."}]},{"type":"heading","level":2,"text":"Rules","anchor":"Rules"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Property names and env-var names must be bare ASCII identifiers (","type":"text"},{"code":"[A-Za-z_][A-Za-z0-9_]*","type":"codeVoice"},{"text":"). No quoting.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"#"},{"text":" at the start of a line is a comment. Inline comments after a value are not supported.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Blank lines are fine. Tabs are not — anywhere.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flat mode: no leading whitespace on mapping lines."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Sectioned mode: section headers at column 1, content at exactly 2-space indent."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Every declared secret is required at build time. If an env var is unset, the build fails with a message pointing at the missing variable. Truly optional values should be read from "},{"type":"codeVoice","code":"ProcessInfo"},{"type":"text","text":" at runtime rather than declared here."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Duplicate keys, empty files, and anything else outside this grammar are parse errors with a line number.","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":2,"text":"Format Detection","anchor":"Format-Detection"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parser auto-detects format from the first non-comment line:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If it has the shape "},{"code":"key: value","type":"codeVoice"},{"type":"text","text":", the file is "},{"inlineContent":[{"type":"text","text":"flat"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If it has the shape "},{"type":"codeVoice","code":"name:"},{"type":"text","text":" (no value), the file is "},{"type":"strong","inlineContent":[{"type":"text","text":"sectioned"}]},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"A single file cannot mix the two.","type":"text"}]},{"type":"heading","level":2,"text":"Error Messages","anchor":"Error-Messages"},{"type":"paragraph","inlineContent":[{"text":"Parse errors print as ","type":"text"},{"code":"<path>:<line>: <reason>","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":null,"code":["error: Secrets.yml:1: tab character not allowed; use spaces","error: Secrets.yml:1: expected '<name>: <ENV_VAR>', got 'foo BAR'","error: Secrets.yml:3: duplicate key 'foo' (first defined on line 1)","error: Secrets.yml: no secrets declared"]},{"type":"paragraph","inlineContent":[{"text":"The line number is omitted for whole-file errors like an empty config.","type":"text"}]},{"anchor":"Common-Pitfalls","type":"heading","level":2,"text":"Common Pitfalls"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Tabs from a paste:"}]},{"text":" “expected ‘","type":"text"},{"text":": <ENV_VAR>’” usually means an invisible tab. Re-type the line.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Quoted values:","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"foo: \"BAR\""},{"type":"text","text":" fails — quotes aren’t accepted."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Inline comments:"}]},{"text":" ","type":"text"},{"code":"foo: BAR # comment","type":"codeVoice"},{"text":" fails — comments are line-level only.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Hyphenated identifiers:"}],"type":"strong"},{"text":" ","type":"text"},{"code":"revenue-cat-key: ...","type":"codeVoice"},{"text":" fails — use camelCase Swift identifiers.","type":"text"}]}]}]}]}],"hierarchy":{"paths":[["doc:\/\/TightlipCore\/documentation\/TightlipCore"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"The accepted shape of ","type":"text"},{"type":"codeVoice","code":"Secrets.yml"},{"text":", line by line.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/tightlipcore\/configgrammar"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"Tightlip"}],"title":"Config Grammar","role":"article","roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/ConfigGrammar"},"kind":"article","references":{"doc://TightlipCore/documentation/TightlipCore/EnvironmentSelection":{"url":"\/documentation\/tightlipcore\/environmentselection","title":"Environment Selection","abstract":[{"type":"text","text":"How Tightlip picks the active section for a sectioned config."}],"type":"topic","identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/EnvironmentSelection","kind":"article","role":"article"},"doc://TightlipCore/documentation/TightlipCore/SectionedConfigs":{"role":"article","title":"Multi-Environment Configs","url":"\/documentation\/tightlipcore\/sectionedconfigs","identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/SectionedConfigs","kind":"article","type":"topic","abstract":[{"type":"text","text":"Declare staging and production secrets in one file and select between them per build."}]},"doc://TightlipCore/documentation/TightlipCore/GettingStarted":{"identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore\/GettingStarted","url":"\/documentation\/tightlipcore\/gettingstarted","role":"article","abstract":[{"type":"text","text":"Add the plugin to a target, drop in a "},{"type":"codeVoice","code":"Secrets.yml"},{"type":"text","text":", and start reading secrets at compile time."}],"type":"topic","kind":"article","title":"Getting Started with Tightlip"},"doc://TightlipCore/documentation/TightlipCore":{"identifier":"doc:\/\/TightlipCore\/documentation\/TightlipCore","type":"topic","abstract":[{"type":"text","text":"A SwiftPM build-tool plugin that generates a typed Swift "},{"type":"codeVoice","code":"Secrets"},{"type":"text","text":" enum from environment variables at build time."}],"title":"Tightlip","kind":"symbol","url":"\/documentation\/tightlipcore","role":"collection"}}}